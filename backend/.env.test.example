# Copy to .env.test and do not commit .env.test.
# Used by docker-compose.test.yml and local pytest.

# Test database (inside Docker network use postgres:5432; locally use localhost:5433)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/carousel_test

# PostgreSQL (for docker-compose.test.yml postgres service)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=carousel_test

# Minimal S3/CORS/LLM (same as .env.example or leave minimal)
S3_ENDPOINT=http://minio:9000
S3_BUCKET=carousel
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
