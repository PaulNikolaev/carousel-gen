# Copy to .env and fill in values. Do not commit .env.

# Database (PostgreSQL, async driver)
# Format: postgresql+asyncpg://user:password@host:port/dbname
# When running in Docker use @postgres:5432, for local dev use @localhost:5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/carousel

# PostgreSQL (for docker-compose postgres service)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=carousel

# MinIO (for docker-compose minio service)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# S3-compatible storage (e.g. MinIO)
# Leave empty if not used yet.
# When running in Docker use http://minio:9000, for local dev use http://localhost:9000
S3_ENDPOINT=http://minio:9000
S3_BUCKET=carousel
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# LLM API (for carousel generation)
# API key and base URL for the model endpoint.
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
