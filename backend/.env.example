# Copy to .env and fill in values. Do not commit .env.

# Database (PostgreSQL, async driver)
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/carousel

# S3-compatible storage (e.g. MinIO)
# Leave empty if not used yet.
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=carousel
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key

# LLM API (for carousel generation)
# API key and base URL for the model endpoint.
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
